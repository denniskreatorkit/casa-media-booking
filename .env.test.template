# Test credentials template — copy to .env.test and fill in real values.
# .env.test is gitignored; never commit actual credentials.

# Database (use a separate test database, not production)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/casamedia_test?schema=public"

# NextAuth (test environment)
NEXTAUTH_SECRET="test-secret-change-me"
NEXTAUTH_URL="http://localhost:3000"

# Google Maps API — test key (restricted usage)
# Get from: Google Cloud Console → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY_TEST=""

# Google Calendar OAuth — test account/calendar
# Get from: Google Cloud Console → OAuth 2.0 Client IDs
GOOGLE_CALENDAR_CLIENT_ID_TEST=""
GOOGLE_CALENDAR_CLIENT_SECRET_TEST=""
GOOGLE_CALENDAR_REFRESH_TOKEN_TEST=""
GOOGLE_CALENDAR_ID_TEST=""

# Go High Level — test sub-account
# Get from: GHL Agency → Settings → Private Integrations
GHL_API_KEY_TEST=""
GHL_LOCATION_ID_TEST=""

# Upstash Redis (optional for tests)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
