    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.1",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "prisma": "^7.7.0",
    "react": "^18",
    "react-dom": "^18",
    "vercel": "^50.42.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
